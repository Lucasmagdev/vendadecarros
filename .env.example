API_PORT=8787
HOST=127.0.0.1
APP_PORT=3100
DATA_DIR=./data

# Protecao do painel quando ele estiver publicado.
APP_USERNAME=admin
APP_PASSWORD=troque-por-uma-senha-forte

# Base da sua Evolution API, sem barra no final.
EVOLUTION_API_URL=http://localhost:8080

# Use a global API key ou token da instância.
EVOLUTION_API_KEY=coloque-sua-chave-aqui

# Nome da instância criada/conectada na Evolution API.
EVOLUTION_INSTANCE=loja-whatsapp

# true = simula envio; false = envia de verdade.
EVOLUTION_DRY_RUN=true

# Opcional: respostas geradas por IA. Sem chave, o sistema usa os textos de fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# true executa o recebimento e as respostas no servidor, sem depender do painel aberto.
SERVER_WORKER_ENABLED=false
